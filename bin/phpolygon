#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * PHPolygon CLI — Game build tool
 *
 * Usage:
 *   php bin/phpolygon build [platform] [options]
 *
 * Platforms:
 *   macos-arm64, macos-x86_64, linux-x86_64, linux-arm64, windows-x86_64
 *   macos, linux, windows (all archs for that platform)
 *   all (every platform)
 *   (empty) = auto-detect current platform
 *
 * Options:
 *   --dry-run          Show resolved config without building
 *   --micro-sfx PATH   Path to a pre-built micro.sfx binary
 *   --output DIR        Output directory (default: build/)
 *   --variant NAME      Build variant: base or steam (default: base)
 *   --type NAME         Build type from build.json (default: full)
 *   --php-version VER   PHP runtime version: 8.4 or 8.5 (default: 8.5)
 */

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',          // Standalone / dev
    __DIR__ . '/../../../autoload.php',            // Installed as dependency
];

$autoloader = null;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        $autoloader = $path;
        break;
    }
}

if ($autoloader === null) {
    fwrite(STDERR, "Error: Could not find autoloader. Run 'composer install' first.\n");
    exit(1);
}

require $autoloader;

use PHPolygon\Build\BuildConfig;
use PHPolygon\Build\GameBuilder;
use PHPolygon\Build\StaticPhpResolver;
use PHPolygon\Component\MeshRenderer;
use PHPolygon\Geometry\BoxMesh;
use PHPolygon\Geometry\CylinderMesh;
use PHPolygon\Geometry\MeshRegistry;
use PHPolygon\Geometry\PlaneMesh;
use PHPolygon\Geometry\SphereMesh;
use PHPolygon\Prototype\PrototypeExporter;
use PHPolygon\Prototype\SerializableScanner;
use PHPolygon\Rendering\Material;
use PHPolygon\Rendering\MaterialRegistry;
use PHPolygon\Scene\Scene;
use PHPolygon\Scene\Transpiler\GameEntryGenerator;
use PHPolygon\Scene\Transpiler\SceneImportGenerator;
use PHPolygon\Scene\Transpiler\SceneTranspiler;

// --- Parse CLI arguments ---

$args = array_slice($argv, 1);
$command = null;
$platformArg = '';
$options = [
    'dry-run' => false,
    'micro-sfx' => null,
    'output' => '',
    'variant' => 'base',
    'type' => 'full',
    'php-version' => '8.5',
    'release' => false,
    'ipa' => false,
    'game' => null, // scene:import game entry: null=auto-scaffold, false=skip, string=force path
];

$i = 0;
while ($i < count($args)) {
    $arg = $args[$i];

    if ($arg === '--dry-run') {
        $options['dry-run'] = true;
    } elseif ($arg === '--game' && isset($args[$i + 1])) {
        $options['game'] = $args[++$i];
    } elseif ($arg === '--no-game') {
        $options['game'] = false;
    } elseif ($arg === '--micro-sfx' && isset($args[$i + 1])) {
        $options['micro-sfx'] = $args[++$i];
    } elseif (($arg === '--output' || $arg === '--out') && isset($args[$i + 1])) {
        $options['output'] = $args[++$i];
    } elseif ($arg === '-o' && isset($args[$i + 1])) {
        $options['output'] = $args[++$i];
    } elseif ($arg === '--variant' && isset($args[$i + 1])) {
        $options['variant'] = $args[++$i];
    } elseif ($arg === '--type' && isset($args[$i + 1])) {
        $options['type'] = $args[++$i];
    } elseif ($arg === '--php-version' && isset($args[$i + 1])) {
        $options['php-version'] = $args[++$i];
    } elseif ($arg === '--release') {
        $options['release'] = true;
    } elseif ($arg === '--ipa') {
        // App Store .ipa export implies a release archive.
        $options['release'] = true;
        $options['ipa'] = true;
    } elseif ($arg === '--help' || $arg === '-h') {
        printUsage();
        exit(0);
    } elseif (!str_starts_with($arg, '-') && $command === null) {
        $command = $arg;
    } elseif (!str_starts_with($arg, '-') && $command !== null && $platformArg === '') {
        $platformArg = $arg;
    }
    $i++;
}

// --- Dispatch ---

if ($command === null || $command === 'help') {
    printUsage();
    exit(0);
}

if ($command === 'editor') {
    launchEditor();
    exit(0);
}

if ($command === 'perf:report') {
    $rest = array_values(array_filter($args, fn(string $a): bool => $a !== 'perf:report'));
    perfReport($rest);
    exit(0);
}

if ($command === 'prototype:export') {
    prototypeExport($options['output']);
    exit(0);
}

if ($command === 'scene:transpile') {
    sceneTranspile($platformArg, $options['output']);
    exit(0);
}

if ($command === 'scene:import') {
    sceneImport($platformArg, $options['output'], $options['game']);
    exit(0);
}

if ($command === 'prototype:import') {
    prototypeImport($platformArg, $options['output'], $options['game']);
    exit(0);
}

if ($command === 'prototype:scaffold') {
    prototypeScaffold($options['output']);
    exit(0);
}

if ($command !== 'build') {
    fwrite(STDERR, "Unknown command: {$command}\n");
    printUsage();
    exit(1);
}

// --- Build command ---

$projectRoot = getcwd() ?: dirname(__DIR__);
$config = BuildConfig::load($projectRoot);

$outputDir = $options['output'] !== '' ? $options['output'] : $projectRoot . '/build';
$microSfxPath = $options['micro-sfx'];
$variant = $options['variant'];
$buildType = $options['type'];
$phpVersion = $options['php-version'];
$iosRelease = $options['release'];
$iosExportIpa = $options['ipa'];

if (!in_array($variant, ['base', 'steam'], true)) {
    fwrite(STDERR, "Error: Unknown variant '{$variant}'. Use 'base' or 'steam'.\n");
    exit(1);
}

if ($buildType !== 'full' && !isset($config->buildTypes[$buildType])) {
    $available = empty($config->buildTypes) ? '(none defined)' : implode(', ', array_keys($config->buildTypes));
    fwrite(STDERR, "Error: Unknown build type '{$buildType}'. Available: full, {$available}\n");
    exit(1);
}

$targets = resolveTargets($platformArg);

if ($options['dry-run']) {
    dryRun($config, $targets, $outputDir, $microSfxPath);
    exit(0);
}

if (ini_get('phar.readonly')) {
    fwrite(STDERR, "\033[31mError:\033[0m phar.readonly is enabled. Run with:\n");
    fwrite(STDERR, "  php -d phar.readonly=0 vendor/bin/phpolygon build\n");
    exit(1);
}

$builder = new GameBuilder($config);
$builder->setLogger(function (string $level, string $message): void {
    $prefix = match ($level) {
        'success' => "\033[32m✓\033[0m",
        'info' => "\033[34m→\033[0m",
        default => ' ',
    };
    echo "  {$prefix} {$message}\n";
});

$results = [];
foreach ($targets as $targetName => $target) {
    echo "\n";
    echo "\033[1mPHPolygon Game Builder\033[0m\n";
    echo str_repeat('-', 50) . "\n";
    echo "  Game:     {$config->name} v{$config->version}\n";
    echo "  Target:   {$targetName}\n";
    echo "  Variant:  {$variant}\n";
    echo "  Type:     {$buildType}\n";
    echo "  PHP:      {$phpVersion}\n";
    echo "  Output:   {$outputDir}\n";
    echo str_repeat('-', 50) . "\n\n";

    try {
        $result = $builder->build(
            $target['platform'],
            $outputDir,
            $microSfxPath,
            $target['arch'],
            $variant,
            $buildType,
            $phpVersion,
            $iosRelease,
            $iosExportIpa,
        );
        $results[$targetName] = $result;

        echo "\n";
        echo "  \033[32m✓\033[0m {$targetName} complete!\n";
        echo sprintf("  PHAR:   %.2f MB\n", $result['pharSize'] / 1024 / 1024);
        echo sprintf("  Binary: %.2f MB\n", $result['binarySize'] / 1024 / 1024);
        echo sprintf("  Total:  %.2f MB\n", $result['bundleSize'] / 1024 / 1024);
        echo "  Output: {$result['outputPath']}\n";
    } catch (\Throwable $e) {
        echo "\n";
        fwrite(STDERR, "  \033[31m✗ {$targetName} failed:\033[0m {$e->getMessage()}\n");
    }
}

if (count($results) > 0) {
    echo "\n" . str_repeat('=', 50) . "\n";
    echo sprintf("  \033[32m✓\033[0m Built %d/%d targets\n", count($results), count($targets));
    foreach ($results as $name => $r) {
        echo sprintf("  %-20s %.2f MB  %s\n", $name, $r['bundleSize'] / 1024 / 1024, $r['outputPath']);
    }
    echo str_repeat('=', 50) . "\n";
}

exit(count($results) === count($targets) ? 0 : 1);

// --- Helper functions ---

/**
 * @return array<string, array{platform: string, arch: string}>
 */
function resolveTargets(string $platformArg): array
{
    $allTargets = [
        'macos-arm64'     => ['platform' => 'macos',   'arch' => 'arm64'],
        'macos-x86_64'    => ['platform' => 'macos',   'arch' => 'x86_64'],
        'linux-x86_64'    => ['platform' => 'linux',   'arch' => 'x86_64'],
        'linux-arm64'     => ['platform' => 'linux',   'arch' => 'arm64'],
        'windows-x86_64'  => ['platform' => 'windows', 'arch' => 'x86_64'],
        // iOS: the slice is carried as the platform string (GameBuilder
        // dispatches on str_starts_with($platform, 'ios') and passes it to
        // IosAppBuilder). Not part of 'all' (Apple-only, needs Xcode + signing).
        'ios-arm64'              => ['platform' => 'ios-arm64',             'arch' => 'arm64'],
        'ios-simulator-arm64'    => ['platform' => 'ios-simulator-arm64',   'arch' => 'arm64'],
        'ios-simulator-x86_64'   => ['platform' => 'ios-simulator-x86_64',  'arch' => 'x86_64'],
    ];

    if ($platformArg === '' || $platformArg === 'auto') {
        $platform = StaticPhpResolver::detectPlatform();
        $arch = StaticPhpResolver::detectArch();
        $key = "{$platform}-{$arch}";
        return [$key => ['platform' => $platform, 'arch' => $arch]];
    }

    if ($platformArg === 'all') {
        // linux-arm64 excluded from 'all' — not a Steam target.
        // iOS slices excluded — Apple-only, need Xcode + signing, built explicitly.
        unset($allTargets['linux-arm64']);
        foreach (array_keys($allTargets) as $name) {
            if (str_starts_with($name, 'ios')) {
                unset($allTargets[$name]);
            }
        }
        return $allTargets;
    }

    if (isset($allTargets[$platformArg])) {
        return [$platformArg => $allTargets[$platformArg]];
    }

    // 'ios' shorthand → on-device arm64 slice
    if ($platformArg === 'ios') {
        return ['ios-arm64' => $allTargets['ios-arm64']];
    }

    // Platform-only match
    $matched = [];
    foreach ($allTargets as $name => $target) {
        if ($target['platform'] === $platformArg) {
            $matched[$name] = $target;
        }
    }

    if (!empty($matched)) {
        return $matched;
    }

    fwrite(STDERR, "Unknown target: {$platformArg}\n");
    fwrite(STDERR, "Available: " . implode(', ', array_keys($allTargets)) . ", macos, linux, windows, all\n");
    exit(1);
}

/**
 * @param array<string, array{platform: string, arch: string}> $targets
 */
function dryRun(BuildConfig $config, array $targets, string $outputDir, ?string $microSfxPath): void
{
    echo "\n\033[1mPHPolygon Build — Dry Run\033[0m\n";
    echo str_repeat('-', 50) . "\n";

    $data = $config->toArray();
    $data['output'] = $outputDir;
    $data['micro-sfx'] = $microSfxPath ?? '(auto-resolve)';
    $data['targets'] = implode(', ', array_keys($targets));

    foreach ($data as $key => $value) {
        if (is_array($value)) {
            echo sprintf("  \033[34m%-25s\033[0m %s\n", $key, json_encode($value));
        } else {
            echo sprintf("  \033[34m%-25s\033[0m %s\n", $key, $value);
        }
    }

    echo "\n";
    $resolver = new StaticPhpResolver();
    foreach ($targets as $name => $target) {
        // iOS links an embed libphp.a (no micro.sfx); report the buildroot.
        if (str_starts_with($target['platform'], 'ios')) {
            $buildroot = getenv('PHPOLYGON_IOS_BUILDROOT')
                ?: ($config->platforms['ios']['buildroot'] ?? null)
                ?: dirname($config->projectRoot) . '/static-php-cli/buildroot';
            if (is_file($buildroot . '/lib/libphp.a')) {
                echo "  \033[32m✓\033[0m {$name}: embed libphp.a at {$buildroot}/lib/libphp.a\n";
            } else {
                echo "  \033[33m!\033[0m {$name}: no libphp.a at {$buildroot}/lib (build with SPC_TARGET={$target['platform']} bin/spc build … --build-embed)\n";
            }
            continue;
        }
        try {
            $sfxPath = $resolver->resolve($microSfxPath, $target['platform'], $target['arch']);
            echo "  \033[32m✓\033[0m {$name}: micro.sfx found at {$sfxPath}\n";
        } catch (\RuntimeException $e) {
            echo "  \033[33m!\033[0m {$name}: " . explode("\n", $e->getMessage())[0] . "\n";
        }
    }

    echo str_repeat('-', 50) . "\n";
}

function launchEditor(): void
{
    // Resolve editor directory: check PHPolygon's own editor/ first,
    // then the project's vendor path
    $candidates = [
        __DIR__ . '/../editor',                          // PHPolygon dev / standalone
        dirname(__DIR__, 3) . '/phpolygon/phpolygon/editor', // Installed as dependency (vendor/)
    ];

    $editorDir = null;
    foreach ($candidates as $path) {
        if (is_dir($path) && file_exists($path . '/artisan')) {
            $editorDir = realpath($path);
            break;
        }
    }

    if ($editorDir === null) {
        fwrite(STDERR, "\033[31mError:\033[0m Editor not found. Checked:\n");
        foreach ($candidates as $path) {
            fwrite(STDERR, "  - {$path}\n");
        }
        exit(1);
    }

    $projectRoot = getcwd() ?: dirname(__DIR__);
    $env = array_merge($_ENV, ['PHPOLYGON_PROJECT_ROOT' => $projectRoot]);
    putenv("PHPOLYGON_PROJECT_ROOT={$projectRoot}");

    echo "\033[1mPHPolygon Editor\033[0m\n";
    echo "  Project: {$projectRoot}\n";
    echo "  Editor:  {$editorDir}\n\n";

    // Ensure Electron deps are installed (native:install may not have run yet)
    $electronDir = $editorDir . '/vendor/nativephp/desktop/resources/electron';
    if (is_dir($electronDir) && !is_dir($electronDir . '/node_modules')) {
        echo "  Installing Electron dependencies...\n";
        passthru('cd ' . escapeshellarg($electronDir) . ' && npm install --no-fund --no-audit 2>&1');
        echo "\n";
    }

    echo "  Starting NativePHP desktop application...\n\n";

    // native:run handles Electron build + PHP server + desktop window
    $descriptors = [STDIN, STDOUT, STDERR];
    $process = proc_open(
        ['php', 'artisan', 'native:run', '--no-interaction'],
        $descriptors,
        $pipes,
        $editorDir,
        $env,
    );

    if (!is_resource($process)) {
        fwrite(STDERR, "\033[31mError:\033[0m Failed to start editor. Try manually:\n");
        fwrite(STDERR, "  cd {$editorDir} && php artisan native:run\n");
        exit(1);
    }

    $exitCode = proc_close($process);
    exit($exitCode);
}

function printUsage(): void
{
    echo <<<'USAGE'

PHPolygon CLI

Usage:
  phpolygon build [platform] [options]
  phpolygon editor
  phpolygon perf:report <scenario> [<sha-a> <sha-b>]
  phpolygon prototype:scaffold [--out DIR]
  phpolygon prototype:export [--out DIR]
  phpolygon scene:transpile <file.scene.json> [--out Scene.php]
  phpolygon scene:import <file.import.json> [--out Scene.php]
  phpolygon prototype:import <file.tsx|file.jsx> [--out Scene.php]

Commands:
  build              Build game for distribution
  editor             Launch the PHPolygon scene editor
  perf:report        Diff two benchmark JSON results in benchmarks/results/
  prototype:scaffold Copy the WebGL/JSX prototyping playground into this project
  prototype:export   Write the static bundle for the WebGL/JSX prototyping playground
  scene:transpile    Transpile a scene JSON file back to canonical PHP Scene source
  scene:import       Generate a self-contained PHP Scene from an R3F-import JSON
  prototype:import   Import a TSX/JSX prototype (R3F / imperative Three.js / gameplay) straight to a PHP Scene

Platforms:
  macos-arm64        macOS Apple Silicon
  macos-x86_64       macOS Intel
  linux-x86_64       Linux x86_64
  linux-arm64        Linux ARM64
  windows-x86_64     Windows x86_64
  ios-arm64          iOS / iPadOS device (needs Xcode + libphp.a embed build)
  ios-simulator-arm64   iOS Simulator (Apple Silicon)
  ios-simulator-x86_64  iOS Simulator (Intel)
  macos              All macOS targets
  linux              All Linux targets
  windows            All Windows targets
  ios                iOS device (ios-arm64 shorthand)
  all                Every desktop platform (excludes iOS)
  (empty)            Auto-detect current platform

Options:
  --dry-run          Show resolved config without building
  --micro-sfx PATH   Path to a pre-built micro.sfx binary
  -o, --output DIR   Output directory (default: build/)
  --variant NAME     Build variant: base or steam (default: base)
  --type NAME        Build type from build.json (default: full)
  --php-version VER  PHP runtime version: 8.4 or 8.5 (default: 8.5)
  --release          iOS only: build a Release .xcarchive (App Store-bound)
  --ipa              iOS only: export an App Store Connect .ipa (implies
                     --release; needs distribution signing)
  -h, --help         Show this help

Examples:
  phpolygon build                                Build for current platform
  phpolygon build macos-arm64                    Build for macOS ARM
  phpolygon build all --variant steam            Build all platforms with Steam
  phpolygon build ios-arm64                      Build the iOS / iPadOS .app (dev)
  phpolygon build ios-arm64 --release            Build a Release .xcarchive (App Store)
  phpolygon build ios-arm64 --ipa                Export an App Store Connect .ipa
  phpolygon build --php-version 8.4              Build with PHP 8.4 runtime
  phpolygon build --dry-run                      Show config without building
  phpolygon editor                       Launch the scene editor
  phpolygon prototype:export             Export the WebGL/JSX prototyping bundle to .phpolygon/prototype
  phpolygon prototype:export --out web   Export the bundle to ./web
  phpolygon scene:transpile s.json       Print PHP Scene source for s.json
  phpolygon scene:transpile s.json --out src/Scene/S.php   Write the PHP Scene file
  phpolygon prototype:import shooter.tsx --out src/Scene/Shooter.php   Import TSX/JSX → PHP Scene in one step
  phpolygon perf:report boxes-1000       Compare last two boxes-1000 results
  phpolygon perf:report boxes-1000 abc123 def456   Compare two specific shas
  phpolygon perf:report boxes-1000 --baseline      Compare latest result vs committed baseline (CI mode)
  phpolygon perf:report boxes-1000 --baseline --threshold 25   Use a custom regression threshold

USAGE;
}

/**
 * @param list<string> $args
 */
function perfReport(array $args): void
{
    $useBaseline = false;
    $threshold = 15.0;
    // Absolute slowdown floor in milliseconds. Regressions with absolute
    // delta below this are treated as CI noise and ignored regardless of
    // percentage. A single GC pause across 300 frames is enough to swing
    // a sub-millisecond p95 by 60-70% even when the code under test
    // hasn't moved. 0.5ms is roughly the upper end of "one bad frame"
    // on shared ubuntu-latest runners.
    $absFloorMs = 0.5;
    $positional = [];
    for ($i = 0; $i < count($args); $i++) {
        if ($args[$i] === '--baseline') {
            $useBaseline = true;
        } elseif ($args[$i] === '--threshold' && isset($args[$i + 1])) {
            $threshold = (float) $args[++$i];
        } elseif ($args[$i] === '--abs-floor-ms' && isset($args[$i + 1])) {
            $absFloorMs = (float) $args[++$i];
        } else {
            $positional[] = $args[$i];
        }
    }

    $scenario = $positional[0] ?? null;
    if ($scenario === null) {
        fwrite(STDERR, "Usage: phpolygon perf:report <scenario> [<sha-a> <sha-b>] [--baseline] [--threshold N] [--abs-floor-ms N]\n");
        exit(1);
    }

    $cwd = getcwd();
    $resultsDir = $cwd . '/benchmarks/results';
    $baselinesDir = $cwd . '/benchmarks/baselines';

    if ($useBaseline) {
        $baselineFile = "{$baselinesDir}/{$scenario}.json";
        if (!file_exists($baselineFile)) {
            fwrite(STDERR, "No baseline for {$scenario}: {$baselineFile}\n");
            fwrite(STDERR, "Generate one with: php benchmarks/run.php {$scenario} --accept\n");
            exit(1);
        }

        $candidates = glob("{$resultsDir}/{$scenario}-*.json") ?: [];
        $matches = array_values(array_filter(
            $candidates,
            fn(string $f): bool => (bool) preg_match(
                '/^' . preg_quote($scenario, '/') . '-[0-9a-f]+\.json$/',
                basename($f)
            ),
        ));
        if ($matches === []) {
            fwrite(STDERR, "No fresh result for {$scenario} in {$resultsDir}\n");
            fwrite(STDERR, "Run: php benchmarks/run.php {$scenario}\n");
            exit(1);
        }
        usort($matches, fn(string $x, string $y): int => filemtime($y) <=> filemtime($x));
        $a = $baselineFile;
        $b = $matches[0];
        runDiff($a, $b, $scenario, $threshold, $absFloorMs);
        return;
    }

    if (!is_dir($resultsDir)) {
        fwrite(STDERR, "No benchmarks/results directory in {$resultsDir}\n");
        exit(1);
    }

    if (isset($positional[1], $positional[2])) {
        $shaA = $positional[1];
        $shaB = $positional[2];
        $a = "{$resultsDir}/{$scenario}-{$shaA}.json";
        $b = "{$resultsDir}/{$scenario}-{$shaB}.json";
    } else {
        // glob is greedy: "boxes-1000-*.json" also matches "boxes-1000-instanced-*.json".
        // Filter for {scenario}-{sha}.json where sha is the short hex hash.
        $candidates = glob("{$resultsDir}/{$scenario}-*.json") ?: [];
        $files = array_values(array_filter(
            $candidates,
            fn(string $f): bool => (bool) preg_match(
                '/^' . preg_quote($scenario, '/') . '-[0-9a-f]+\.json$/',
                basename($f)
            ),
        ));
        if (count($files) < 2) {
            fwrite(STDERR, "Need at least 2 result files for {$scenario} (found " . count($files) . ")\n");
            exit(1);
        }
        usort($files, fn(string $x, string $y): int => filemtime($y) <=> filemtime($x));
        $b = $files[0];
        $a = $files[1];
    }

    runDiff($a, $b, $scenario, $threshold, $absFloorMs);
}

function runDiff(string $a, string $b, string $scenario, float $threshold, float $absFloorMs = 0.5): void
{
    if (!file_exists($a)) {
        fwrite(STDERR, "Missing: {$a}\n");
        exit(1);
    }
    if (!file_exists($b)) {
        fwrite(STDERR, "Missing: {$b}\n");
        exit(1);
    }

    $resultA = json_decode((string) file_get_contents($a), true);
    $resultB = json_decode((string) file_get_contents($b), true);
    if (!is_array($resultA) || !is_array($resultB)) {
        fwrite(STDERR, "Could not parse benchmark JSON\n");
        exit(1);
    }

    $shaA = $resultA['gitSha'] ?? '?';
    $shaB = $resultB['gitSha'] ?? '?';

    echo "\n";
    echo "\033[1mPerf report: {$scenario}\033[0m\n";
    echo "  base: {$shaA} (" . basename($a) . ")\n";
    echo "  head: {$shaB} (" . basename($b) . ")\n";
    echo str_repeat('-', 60) . "\n";

    $worstRegression = 0.0;
    $worstRegressionMetric = '';
    $noiseFloorHits = [];
    // Outlier-prone metrics (minMs/maxMs/p99Ms) are reported but not gated.
    // A single GC pause across 300 frames will always inflate maxMs by
    // 50%+ regardless of the code under test, so failing on max produces
    // false positives even with the absolute-delta floor. The same is true
    // for p99Ms: it is the 99th percentile, i.e. the worst 3 frames of 300,
    // so on sub-millisecond scenarios (mesh-gen-stress, mixed-scene) it is
    // dominated by one scheduler/GC hiccup and routinely swings 40-60% while
    // p50/p95/mean stay flat. This is especially pronounced across a runtime
    // bump (e.g. PHP 8.4 -> 8.5) where the two reference runs use different
    // interpreters. p50/p95/mean are the actual quality signals we gate on;
    // p99 stays visible (and red when it moves) but does not block.
    $gatedMetrics = ['p50Ms', 'p95Ms', 'meanMs'];
    foreach (['p50Ms', 'p95Ms', 'p99Ms', 'meanMs', 'minMs', 'maxMs'] as $key) {
        $av = (float) ($resultA['frame'][$key] ?? 0.0);
        $bv = (float) ($resultB['frame'][$key] ?? 0.0);
        $delta = $av > 0.0 ? (($bv - $av) / $av) * 100.0 : 0.0;
        $absDelta = $bv - $av;
        $isGated = in_array($key, $gatedMetrics, true);
        $countsForGate = $isGated && $absDelta >= $absFloorMs;
        if ($countsForGate && $delta > $worstRegression) {
            $worstRegression = $delta;
            $worstRegressionMetric = $key;
        }
        if ($isGated && $delta > $threshold && !$countsForGate) {
            $noiseFloorHits[] = sprintf('%s (+%.1f%%, +%.3fms < %.2fms floor)', $key, $delta, $absDelta, $absFloorMs);
        }
        $sign = $delta >= 0.0 ? '+' : '';
        $color = match (true) {
            $delta > 5.0 => "\033[31m",
            $delta < -5.0 => "\033[32m",
            default => '',
        };
        $reset = $color !== '' ? "\033[0m" : '';
        $tag = $isGated ? '' : ' (info)';
        printf("  %-7s  %7.3fms -> %7.3fms  %s%s%.1f%%%s%s\n", $key, $av, $bv, $color, $sign, $delta, $reset, $tag);
    }

    $aFps = $resultA['frame']['fps'] ?? 0.0;
    $bFps = $resultB['frame']['fps'] ?? 0.0;
    $fpsDelta = $aFps > 0.0 ? (($bFps - $aFps) / $aFps) * 100.0 : 0.0;
    $fpsSign = $fpsDelta >= 0.0 ? '+' : '';
    printf("  fps      %7.1f    -> %7.1f      %s%.1f%%\n", $aFps, $bFps, $fpsSign, $fpsDelta);

    $sectionsA = is_array($resultA['sections'] ?? null) ? $resultA['sections'] : [];
    $sectionsB = is_array($resultB['sections'] ?? null) ? $resultB['sections'] : [];
    $allSections = array_unique(array_merge(array_keys($sectionsA), array_keys($sectionsB)));

    if ($allSections !== []) {
        echo "\n  Section avg ms:\n";
        foreach ($allSections as $name) {
            $av = (float) ($sectionsA[$name]['avgMs'] ?? 0.0);
            $bv = (float) ($sectionsB[$name]['avgMs'] ?? 0.0);
            if ($av < 0.001 && $bv < 0.001) continue;
            $delta = $av > 0.0 ? (($bv - $av) / $av) * 100.0 : 0.0;
            $sign = $delta >= 0.0 ? '+' : '';
            printf("    %-32s  %7.4f -> %7.4f  %s%.1f%%\n", $name, $av, $bv, $sign, $delta);
        }
    }

    echo "\n";

    if ($noiseFloorHits !== []) {
        echo "  Ignored (below " . sprintf('%.2fms', $absFloorMs) . " absolute-delta floor):\n";
        foreach ($noiseFloorHits as $hit) {
            echo "    - {$hit}\n";
        }
        echo "\n";
    }

    if ($worstRegression > $threshold) {
        printf(
            "\033[31mREGRESSION: %s is %.1f%% slower (threshold %.0f%%, abs floor %.2fms)\033[0m\n",
            $worstRegressionMetric,
            $worstRegression,
            $threshold,
            $absFloorMs,
        );
        exit(2);
    }
    echo "OK\n";
}

/**
 * Export the static bundle the WebGL/JSX prototyping playground consumes.
 *
 * Registers a default primitive mesh palette, runs an optional project
 * bootstrap (prototype.php in the project root, which may register meshes /
 * materials and return a list of Scene instances), discovers the engine's
 * #[Serializable] components, then writes the bundle via PrototypeExporter.
 * Pure data export - no GPU, no window.
 */
function prototypeExport(string $outputOption): void
{
    $projectRoot = getcwd() ?: dirname(__DIR__);

    // 1. Default primitive palette - lets a fresh project preview immediately.
    MeshRegistry::register('box_1x1x1', BoxMesh::generate(1.0, 1.0, 1.0));
    MeshRegistry::register('sphere_r1', SphereMesh::generate(1.0, 12, 16));
    MeshRegistry::register('cylinder_r1', CylinderMesh::generate(1.0, 2.0, 16));
    MeshRegistry::register('plane_1x1', PlaneMesh::generate(1.0, 1.0));
    MaterialRegistry::register('default', Material::default());

    // 2. Optional project bootstrap. May register more meshes/materials as a
    //    side effect and `return [new MyScene(), ...]` to export scenes.
    $scenes = [];
    $bootstrap = $projectRoot . '/prototype.php';
    if (is_file($bootstrap)) {
        echo "  \033[34m→\033[0m Loading prototype.php\n";
        $result = require $bootstrap;
        if (is_array($result)) {
            foreach ($result as $item) {
                if ($item instanceof Scene) {
                    $scenes[] = $item;
                }
            }
        }
    }

    // 3. Discover components: engine + the project's own #[Serializable] ones.
    $components = discoverComponents($projectRoot);

    // 4. Gather everything currently registered.
    $meshes = [];
    foreach (MeshRegistry::ids() as $id) {
        $mesh = MeshRegistry::get($id);
        if ($mesh !== null) {
            $meshes[$id] = $mesh;
        }
    }
    $materials = [];
    foreach (MaterialRegistry::ids() as $id) {
        $material = MaterialRegistry::get($id);
        if ($material !== null) {
            $materials[$id] = $material;
        }
    }

    $outDir = $outputOption !== '' ? $outputOption : $projectRoot . '/.phpolygon/prototype';

    echo "\n\033[1mPHPolygon Prototype Export\033[0m\n";
    echo str_repeat('-', 50) . "\n";

    $manifest = (new PrototypeExporter())->export($outDir, $components, $meshes, $materials, $scenes);

    echo sprintf("  \033[32m✓\033[0m %d components\n", count($components));
    echo sprintf("  \033[32m✓\033[0m %d meshes\n", count($manifest['meshes']));
    echo sprintf("  \033[32m✓\033[0m %d materials\n", count($manifest['materialIds']));
    echo sprintf("  \033[32m✓\033[0m %d scenes\n", count($manifest['scenes']));
    echo "  Output: {$outDir}\n";
    echo str_repeat('-', 50) . "\n";
}

/**
 * Transpile a scene JSON file (the playground's export, or any
 * `_version`-tagged scene JSON) back to canonical PHP Scene source. Writes to
 * --output when given, otherwise prints to stdout.
 */
function sceneTranspile(string $input, string $outputOption): void
{
    if ($input === '') {
        fwrite(STDERR, "Usage: phpolygon scene:transpile <file.scene.json> [--output Scene.php]\n");
        exit(1);
    }
    if (!is_file($input)) {
        fwrite(STDERR, "\033[31mError:\033[0m File not found: {$input}\n");
        exit(1);
    }

    try {
        $php = (new SceneTranspiler())->fromJsonFile($input);
    } catch (\Throwable $e) {
        fwrite(STDERR, "\033[31mError:\033[0m {$e->getMessage()}\n");
        exit(1);
    }

    if ($outputOption !== '') {
        if (file_put_contents($outputOption, $php) === false) {
            fwrite(STDERR, "\033[31mError:\033[0m Failed to write {$outputOption}\n");
            exit(1);
        }
        echo "\033[32m✓\033[0m Wrote {$outputOption}\n";
        return;
    }

    echo $php . "\n";
}

/**
 * Discover #[Serializable] components for the schema: the engine's own
 * (resolved via reflection so it works under vendor/) plus the project's, read
 * from its composer.json PSR-4 autoload roots and narrowed to actual
 * components so non-component serializables don't leak into the vocabulary.
 *
 * @return list<class-string>
 */
function discoverComponents(string $projectRoot): array
{
    $components = [];

    $engineFile = (new ReflectionClass(MeshRenderer::class))->getFileName();
    if ($engineFile !== false) {
        $components = SerializableScanner::scan(dirname($engineFile), 'PHPolygon\\Component');
    }

    $composerPath = $projectRoot . '/composer.json';
    if (is_file($composerPath)) {
        $composer = json_decode((string) file_get_contents($composerPath), true);
        $psr4 = is_array($composer) ? ($composer['autoload']['psr-4'] ?? []) : [];
        if (is_array($psr4)) {
            foreach ($psr4 as $prefix => $paths) {
                $prefix = rtrim((string) $prefix, '\\');
                if ($prefix === 'PHPolygon') {
                    continue; // the engine itself, already covered above
                }
                foreach ((array) $paths as $path) {
                    $dir = $projectRoot . '/' . rtrim((string) $path, '/');
                    $components = array_merge(
                        $components,
                        SerializableScanner::scan($dir, $prefix, \PHPolygon\ECS\AbstractComponent::class),
                    );
                }
            }
        }
    }

    return array_values(array_unique($components));
}

/**
 * Copy the playground (the package's tools/prototype) into the game project so
 * it can be run there, instead of from inside vendor/. Rewires nothing in code
 * (the app fetches /bundle regardless of location); prints the project-relative
 * commands to run.
 */
function prototypeScaffold(string $outputOption): void
{
    $source = dirname(__DIR__) . '/tools/prototype';
    if (!is_dir($source)) {
        fwrite(STDERR, "\033[31mError:\033[0m Playground source not found at {$source}\n");
        exit(1);
    }

    $projectRoot = getcwd() ?: dirname(__DIR__);
    $target = $outputOption !== '' ? $outputOption : $projectRoot . '/prototype';

    if (realpath($source) === realpath($target)) {
        fwrite(STDERR, "\033[31mError:\033[0m Refusing to scaffold onto the source itself.\n");
        exit(1);
    }
    if (is_dir($target)) {
        fwrite(STDERR, "\033[31mError:\033[0m Target already exists: {$target}\n  Remove it or pass --out <dir>.\n");
        exit(1);
    }

    $count = copyTree($source, $target, ['node_modules', 'package-lock.json', 'dist', 'public/bundle']);

    $rel = str_starts_with($target, $projectRoot . '/') ? substr($target, strlen($projectRoot) + 1) : $target;

    echo "\n\033[1mPHPolygon Prototype Playground scaffolded\033[0m\n";
    echo str_repeat('-', 50) . "\n";
    echo "  To: {$target}  ({$count} files)\n";
    echo str_repeat('-', 50) . "\n\n";
    echo "Next steps (from your project root):\n";
    echo "  \033[34m1.\033[0m vendor/bin/phpolygon prototype:export --out {$rel}/public/bundle\n";
    echo "  \033[34m2.\033[0m cd {$rel} && npm install && npm run gen && npm run dev\n\n";
}

/**
 * Recursively copy $source into $target, skipping paths (relative to $source,
 * e.g. "public/bundle") in $exclude. Returns the number of files copied.
 *
 * @param list<string> $exclude
 */
function copyTree(string $source, string $target, array $exclude = [], string $base = ''): int
{
    if (!is_dir($target) && !mkdir($target, 0o775, true) && !is_dir($target)) {
        fwrite(STDERR, "\033[31mError:\033[0m Failed to create {$target}\n");
        exit(1);
    }

    $entries = scandir($source);
    if ($entries === false) {
        return 0;
    }

    $count = 0;
    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..') {
            continue;
        }
        $rel = $base === '' ? $entry : $base . '/' . $entry;
        if (in_array($rel, $exclude, true)) {
            continue;
        }
        $src = $source . '/' . $entry;
        $dst = $target . '/' . $entry;
        if (is_dir($src)) {
            $count += copyTree($src, $dst, $exclude, $rel);
        } elseif (copy($src, $dst)) {
            $count++;
        } else {
            fwrite(STDERR, "\033[31mError:\033[0m Failed to copy {$src}\n");
            exit(1);
        }
    }

    return $count;
}

/**
 * Generate a self-contained PHP Scene from an import.json (produced by the
 * R3F TSX importer). Registers procedural meshes + materials and places the
 * imported entities. Writes to --output when given, otherwise stdout.
 */
function sceneImport(string $input, string $outputOption, string|bool|null $gameOption = null): void
{
    if ($input === '') {
        fwrite(STDERR, "Usage: phpolygon scene:import <file.import.json> [--out Scene.php] [--game game.php | --no-game]\n");
        exit(1);
    }
    if (!is_file($input)) {
        fwrite(STDERR, "\033[31mError:\033[0m File not found: {$input}\n");
        exit(1);
    }

    $contents = file_get_contents($input);
    $data = $contents !== false ? json_decode($contents, true) : null;
    if (!is_array($data)) {
        fwrite(STDERR, "\033[31mError:\033[0m Invalid import JSON: {$input}\n");
        exit(1);
    }

    /** @var array<string, mixed> $data */
    emitImportedScene($data, $outputOption, $gameOption);
}

/**
 * One-step TSX/JSX → PHP Scene import. Runs the layered scene importer (Node)
 * on a `.tsx`/`.jsx` file to produce the import bundle in memory, then feeds it
 * through the same generators as scene:import — no intermediate `*.import.json`
 * on disk.
 *
 * The importer is `scene-extract.mjs` (preferred), which covers three tiers:
 *   1. declarative react-three-fiber JSX (static parse),
 *   2. imperative Three.js (executes the file with a mocked React + patched
 *      THREE, then traverses the built scene graph),
 *   3. data-driven gameplay (platforms/coins/enemies/goal) annotation.
 * Falls back to `r3f-import.mjs` (tier 1 only) when scene-extract isn't found.
 *
 * Needs Node plus the prototype's deps (run `npm install` in prototype/ once).
 *
 * Tier 2 EXECUTES the input file — only import code you trust.
 */
function prototypeImport(string $input, string $outputOption, string|bool|null $gameOption = null): void
{
    if ($input === '') {
        fwrite(STDERR, "Usage: phpolygon prototype:import <file.tsx|file.jsx> [--out Scene.php] [--game game.php | --no-game]\n");
        exit(1);
    }
    if (!is_file($input)) {
        fwrite(STDERR, "\033[31mError:\033[0m File not found: {$input}\n");
        exit(1);
    }

    $projectRoot = getcwd() ?: dirname(__DIR__);

    // Prefer the project's scaffolded importer (its node_modules carries the
    // deps); fall back to the engine's own copy under tools/. scene-extract
    // (layered: declarative + imperative + gameplay) is preferred over the
    // declarative-only r3f-import.
    $searchDirs = [
        $projectRoot . '/prototype/scripts',
        dirname(__DIR__) . '/tools/prototype/scripts',
    ];
    $script = null;
    foreach (['scene-extract.mjs', 'r3f-import.mjs'] as $name) {
        foreach ($searchDirs as $dir) {
            if (is_file($dir . '/' . $name)) {
                $script = $dir . '/' . $name;
                break 2;
            }
        }
    }
    if ($script === null) {
        fwrite(STDERR, "\033[31mError:\033[0m Scene importer not found. Run 'phpolygon prototype:scaffold' first.\n");
        exit(1);
    }

    echo "  \033[34m→\033[0m Parsing {$input} via " . basename($script) . "\n";
    $json = runNode([$script, $input]);
    $data = json_decode($json, true);
    if (!is_array($data)) {
        fwrite(STDERR, "\033[31mError:\033[0m R3F importer produced no valid JSON.\n");
        exit(1);
    }

    /** @var array<string, mixed> $data */
    emitImportedScene($data, $outputOption, $gameOption);
}

/**
 * Shared tail for scene:import and prototype:import: run the import bundle
 * through the generators, write the Scene (or print to stdout when no --out),
 * surface the importer's warnings, and scaffold game.php unless suppressed.
 *
 * @param array<string, mixed> $data
 */
function emitImportedScene(array $data, string $outputOption, string|bool|null $gameOption): void
{
    // When writing to a file, the generated class name must match the file
    // name for PSR-4 autoloading — and the scaffolded game.php must reference
    // that same class. Both generators derive the class from $data['name']
    // (StudlyCase), so align name with the --out basename:
    //   --out src/Scene/Shooter.php  →  class Shooter  →  use App\Scene\Shooter
    // Without this the class follows the input file name (e.g. neon_shooter_3d
    // → NeonShooter3d) and never autoloads from Shooter.php. Name the output
    // file like a PSR-4 class (PascalCase) so StudlyCase is a no-op.
    if ($outputOption !== '') {
        $base = preg_replace('/\.php$/i', '', basename($outputOption));
        if (is_string($base) && $base !== '') {
            $data['name'] = $base;
        }
    }

    if (isset($data['warnings']) && is_array($data['warnings']) && $data['warnings'] !== []) {
        foreach ($data['warnings'] as $warning) {
            fwrite(STDERR, "\033[33m!\033[0m " . (is_string($warning) ? $warning : json_encode($warning)) . "\n");
        }
    }

    try {
        $php = (new SceneImportGenerator())->generate($data);
    } catch (\Throwable $e) {
        fwrite(STDERR, "\033[31mError:\033[0m {$e->getMessage()}\n");
        exit(1);
    }

    if ($outputOption === '') {
        echo $php . "\n";
        return;
    }

    if (file_put_contents($outputOption, $php) === false) {
        fwrite(STDERR, "\033[31mError:\033[0m Failed to write {$outputOption}\n");
        exit(1);
    }
    echo "\033[32m✓\033[0m Wrote {$outputOption}\n";

    // Also generate a runnable game.php (backend chosen per platform at runtime).
    // Default: scaffold ./game.php if absent. --game <path> forces; --no-game skips.
    if ($gameOption === false) {
        return;
    }
    $projectRoot = getcwd() ?: dirname(__DIR__);
    $gamePath = is_string($gameOption) ? $gameOption : $projectRoot . '/game.php';
    if (!is_string($gameOption) && is_file($gamePath)) {
        echo "  \033[34m→\033[0m game.php exists - kept (use --game <path> to overwrite, --no-game to skip)\n";
        return;
    }
    $gameSrc = (new GameEntryGenerator())->generate($data);
    if (file_put_contents($gamePath, $gameSrc) === false) {
        fwrite(STDERR, "\033[31mError:\033[0m Failed to write {$gamePath}\n");
        exit(1);
    }
    echo "\033[32m✓\033[0m Generated game entry: {$gamePath}\n";
}

/**
 * Run `node <args...>` and return its captured stdout. The importer streams
 * progress + per-element warnings to stderr (passed through to the user) and
 * writes the JSON bundle to stdout. Exits with a helpful hint when Node is
 * missing or its dependencies (@babel/parser) aren't installed.
 *
 * @param list<string> $args
 */
function runNode(array $args): string
{
    $descriptors = [
        0 => ['pipe', 'r'],
        1 => ['pipe', 'w'],
        2 => ['pipe', 'w'],
    ];
    $process = @proc_open(array_merge(['node'], $args), $descriptors, $pipes);
    if (!is_resource($process)) {
        fwrite(STDERR, "\033[31mError:\033[0m Could not launch Node. Is it installed and on PATH?\n");
        exit(1);
    }
    fclose($pipes[0]);
    $stdout = stream_get_contents($pipes[1]) ?: '';
    $stderr = stream_get_contents($pipes[2]) ?: '';
    fclose($pipes[1]);
    fclose($pipes[2]);
    $exit = proc_close($process);

    if ($stderr !== '') {
        fwrite(STDERR, $stderr);
    }
    if ($exit !== 0) {
        if (str_contains($stderr, '@babel/parser') || str_contains($stderr, 'ERR_MODULE_NOT_FOUND')) {
            fwrite(STDERR, "\n\033[33mHint:\033[0m the importer needs its Node deps. Run:\n  cd prototype && npm install\n");
        }
        exit($exit);
    }
    return $stdout;
}
