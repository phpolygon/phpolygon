{
    "name": "phpolygon/phpolygon",
    "description": "PHP-native game engine with AI-first authoring",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-glfw": "*",
        "ext-vulkan": "*"
    },
    "suggest": {
        "ext-gd": "Required for logo/image generation tools",
        "ext-ffi": "Alternative GPU binding mechanism (not used for frame-critical calls)"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PHPolygon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPolygon\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/phpolygon"],
    "minimum-stability": "stable",
    "prefer-stable": true
}
