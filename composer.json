{
    "name": "phpolygon/phpolygon",
    "description": "PHP-native game engine with AI-first authoring",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-glfw": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PHPolygon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPolygon\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
